{
  "name": "project",
  "private": true,

  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend-auth\" \"npm run dev --workspace frontend-auth\" \"npm run dev --workspace frontend-web\"",
    "dev:backend": "npm run dev --workspace backend-auth",
    "dev:frontend": "npm run dev --workspace frontend-auth",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "open": "^11.0.0"
  }
}
